# Database - PostgreSQL (production) or SQLite (dev)
# PostgreSQL: postgresql://user:password@host:5432/dbname
# SQLite (dev only, change provider in schema.prisma): file:./dev.db
DATABASE_URL="postgresql://user:password@localhost:5432/diasporaconnect"

# Security
ENCRYPTION_KEY="your_64_char_hex_key_here"
JWT_SECRET="your_jwt_secret_here"

# Blockchain - Polygon Amoy Testnet
RELAYER_PRIVATE_KEY="your_wallet_private_key"
AMOY_RPC_URL="https://rpc-amoy.polygon.technology"

# Twilio SMS (set USE_REAL_TWILIO=true to enable)
USE_REAL_TWILIO="false"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS="*"

# Server
PORT=3000
