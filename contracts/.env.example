# ═══════════════════════════════════════════════════════════════════
#  DiasporaConnect — Variables d'environnement CONTRATS (Hardhat)
# ═══════════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────────┐
# │  IMPORTANT : Ne jamais commit ce fichier dans Git !             │
# │  Il contient ta clé privée. Vérifie que .gitignore est à jour.  │
# └─────────────────────────────────────────────────────────────────┘

# Clé privée de ton wallet MetaMask (SANS le préfixe 0x)
# → Exporter depuis MetaMask : Paramètres > Sécurité > Afficher la clé privée
# → Ce wallet doit avoir du MATIC de test (faucet.polygon.technology)
PRIVATE_KEY=ta_cle_privee_ici_sans_0x

# URL RPC Polygon Amoy Testnet
# → Option 1 (gratuit, sans inscription) :
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
# → Option 2 (plus fiable, compte Alchemy gratuit) :
# AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/ta_cle_alchemy

# Clé API Polygonscan (optionnel, pour vérifier le contrat publiquement)
# → Créer un compte sur https://www.amoy.polygonscan.com/
POLYGONSCAN_API_KEY=

# Activer le rapport de gas (true/false)
REPORT_GAS=false
